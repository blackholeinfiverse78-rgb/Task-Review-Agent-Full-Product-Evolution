{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewResponse",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "PARTIAL",
        "FAIL"
      ]
    },
    "review": {
      "type": "string"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "next_task": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    }
  },
  "required": [
    "status",
    "review",
    "score",
    "next_task",
    "trace_id"
  ]
}